# --- Database (MongoDB) ---
# Leave MONGODB_URI empty to use the local JSON file store (data/ folder).
# Set it to use MongoDB so edits are shared across all visitors.
#
# MongoDB Atlas (free cloud):
#   mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Local MongoDB:
#   mongodb://127.0.0.1:27017
MONGODB_URI=

# Database name (optional, defaults to "rahulraj")
MONGODB_DB=rahulraj

# --- Admin login ---
# Username + password to sign in at /admin (defaults: admin / rahul2026).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Long random string used to sign the admin session cookie.
ADMIN_SECRET=change-me-to-a-long-random-string

# astrologyapi.com credentials (Free Calculators page). Buy credits, then paste your
# User ID + API Key here and in Vercel project env. Calculators show a "setting up"
# message until both are set.
ASTROLOGY_API_USER_ID=
ASTROLOGY_API_KEY=

# Razorpay payment gateway. Set these in Vercel project env (NOT in code).
# Get from Razorpay Dashboard -> Settings -> API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
